# Dungeon.py — LLM Configuration
# Copy this file to .env and fill in your values.
# The game runs fine without any LLM config — all AI features are silently skipped.

# Which provider to use: lm_studio | openai | opencode_zen
LLM_PROVIDER=lm_studio

# --- LM Studio (local) ---
# Start LM Studio, load a model, and enable the local server (default port 1234).
LM_STUDIO_URL=http://127.0.0.1:1234
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=local-model

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- OpenCode Zen ---
OPENCODE_ZEN_URL=
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_MODEL=
